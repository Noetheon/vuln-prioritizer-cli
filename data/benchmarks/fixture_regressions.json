{
  "schema_version": "1.0.0",
  "families": [
    {
      "id": "scanner-json",
      "description": "Scanner and alert exports expressed as JSON documents.",
      "required_edge_signal": "non-cve-or-duplicate-warning"
    },
    {
      "id": "sbom-json",
      "description": "SBOM and dependency-analysis exports expressed as JSON documents.",
      "required_edge_signal": "non-cve-advisory-warning"
    },
    {
      "id": "scanner-xml",
      "description": "Infrastructure scanner XML exports with explicit parser behavior.",
      "required_edge_signal": "non-cve-xml-warning"
    }
  ],
  "cases": [
    {
      "name": "trivy_ci_triage",
      "family": "scanner-json",
      "scenario": "Container CI triage with asset context and OpenVEX suppression.",
      "input": "data/input_fixtures/trivy_report.json",
      "input_format": "trivy-json",
      "fixture_origin": "anonymized-public-fixture",
      "edge_case": true,
      "edge_signals": [
        "non-cve-advisory-warning",
        "vex-suppression"
      ],
      "extra_args": [
        "--asset-context",
        "data/input_fixtures/example_asset_context.csv",
        "--vex-file",
        "data/input_fixtures/openvex_statements.json"
      ],
      "expected_findings_count": 2,
      "expected_filtered_out_count": 1,
      "expected_occurrences_count": 3,
      "expected_source_stats": {
        "trivy-json": 3
      },
      "expected_counts_by_priority": {
        "Critical": 1,
        "High": 1
      },
      "expected_cves": [
        "CVE-2024-4577",
        "CVE-2024-3094"
      ],
      "expected_warning_substrings": [
        "Ignored non-CVE Trivy vulnerability identifier"
      ]
    },
